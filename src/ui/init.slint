import { MainWindow } from "main.slint";

export component InitWindow inherits Window {
    background: transparent;
    title: "VoidPath ED";
    always-on-top: true;
    no-frame: true;
    height: 100px;
    width: 300px;

    in property <bool> is-error: false;
    in property <bool> is-loading: true;
    in property <string> error-message: "";
    in-out property <float> spinner-angle: 0;

    callback close-window();

    Timer {
        interval: 16ms;
        running: is-loading;
        triggered => {
            spinner-angle = mod(spinner-angle + 6, 360);
        }
    }

    Rectangle {
        background: #2A2A2A;
        border-radius: 6px;
        width: 100%;
        height: 100%;

        if is-loading: HorizontalLayout {
            alignment: center;
            padding-top: 6px;
            padding: 16px;
            spacing: 14px;

            VerticalLayout {
                alignment: center;

                Image {
                    source: @image-url("assets/spinner.svg");
                    rotation-angle: spinner-angle * 1deg;
                    colorize: #5DCAA5;
                    image-fit: contain;
                    height: 64px;
                    width: 64px;
                }
            }

            VerticalLayout {
                alignment: center;
                spacing: 3px;

                Text {
                    font-family: "Inter";
                    text: "VoidPath ED";
                    font-weight: 400;
                    color: #FFFFFF;
                    font-size: 14px;
                }

                Text {
                    text: "Checking API connectivity...";
                    font-family: "Inter";
                    font-weight: 400;
                    color: #B4B4B4;
                    font-size: 12px;
                }
            }
        }

        if is-error: VerticalLayout {
            alignment: center;
            padding: 8px;
            spacing: 6px;

            HorizontalLayout {
                alignment: center;

                Image {
                    source: @image-url("assets/error.svg");
                    horizontal-alignment: center;
                    colorize: #FF6B6B;
                    height: 20px;
                    width: 20px;
                }
            }

            Text {
                horizontal-alignment: center;
                font-family: "Inter";
                text: error-message;
                font-weight: 400;
                color: #B4B4B4;
                font-size: 12px;
            }

            HorizontalLayout {
                alignment: center;
                padding-top: 6px;

                Rectangle {
                    background: close-area.has-hover ? #3a3a3a : #2a2a2a;
                    border-color: #B4B4B4;
                    border-width: 0.5px;
                    border-radius: 6px;
                    width: 70px;
                    height: 25px;

                    Text {
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        font-family: "Inter";
                        font-weight: 400;
                        color: #B4B4B4;
                        font-size: 12px;
                        text: "Close";
                    }

                    close-area := TouchArea {
                        clicked => { root.close-window(); }
                    }
                }
            }
        }
    }
}
